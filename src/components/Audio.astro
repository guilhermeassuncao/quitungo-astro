---
const { src, author = '' } = Astro.props;
---

<div class="content">
    <audio class="audio" controls>
        <source src={src} />
    </audio>
    {author && <p class="author">{author}</p>}
</div>

<style>
    .content {
        @apply flex flex-col items-start justify-center gap-2 my-8;
    }

    .audio {
        @apply rounded md:w-3/4;
    }

    .author {
        @apply text-sm text-zinc-400 w-full md:w-3/4;
    }
</style>
